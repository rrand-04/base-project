<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.MenuController"
            style="-fx-background-color: #faf7f4;">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="14" right="28" bottom="10" left="28"/>
                </padding>
                <Button text="← Home" onAction="#backToHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Label fx:id="branchLabel" text="Branch Menu"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userLabel" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
            </HBox>

            <!-- Category tabs -->
            <HBox fx:id="categoryBar" spacing="8" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="0" right="28" bottom="8" left="28"/>
                </padding>
            </HBox>

            <!-- Drinks sub-tabs (Espresso Hot / Cold / Refreshers) -->
            <HBox fx:id="drinksSubBar" spacing="8" alignment="CENTER_LEFT" managed="false" visible="false"
                   style="-fx-background-color: #f5efe9; -fx-border-color: #efe6df; -fx-border-width: 1 0 0 0;">
                <padding>
                    <Insets top="8" right="28" bottom="12" left="28"/>
                </padding>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #faf7f4; -fx-background-color: #faf7f4;">
            <VBox spacing="20" style="-fx-background-color: #faf7f4;">
                <FlowPane fx:id="menuGrid" hgap="18" vgap="18" alignment="TOP_LEFT"
                          style="-fx-background-color: #faf7f4;">
                    <padding>
                        <Insets top="20" right="28" bottom="0" left="28"/>
                    </padding>
                </FlowPane>

                <VBox fx:id="bestSellerSection" spacing="10" maxWidth="860"
                      style="-fx-background-color: #FFF8E1; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 16;">
                    <padding>
                        <Insets left="28" right="28" bottom="28"/>
                    </padding>
                    <Label text="🔥 Most Sold at This Branch"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <ProgressIndicator fx:id="bestSellerProgress" maxWidth="28" maxHeight="28"/>
                        <VBox fx:id="bestSellerContent" spacing="4" visible="false" managed="false">
                            <Label fx:id="bestSellerNameLabel" text="" wrapText="true"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #3e2723;"/>
                            <Label fx:id="bestSellerCategoryLabel" text=""
                                   style="-fx-font-size: 12px; -fx-text-fill: #6d4c41;"/>
                            <Label fx:id="bestSellerQtyLabel" text=""
                                   style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                        </VBox>
                        <Label fx:id="bestSellerEmptyLabel" text="No sales recorded at this branch yet."
                               visible="false" managed="false"
                               style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
