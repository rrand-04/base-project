<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.EmployeeOrderController"
            style="-fx-background-color: #faf7f4;">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="14" right="28" bottom="14" left="28"/>
                </padding>
                <Button text="← Home" onAction="#backToHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Label text="Manage Orders"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox fx:id="showInactiveCheckBox" text="Show cancelled orders"
                          onAction="#loadOrders"
                          style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                <Label text="Filter:" style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                <ComboBox fx:id="statusFilterCombo" prefWidth="140" onAction="#loadOrders"
                          style="-fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 28;">
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label text="All Orders"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>

                <TableView fx:id="ordersTable" prefHeight="340">
                    <columns>
                        <TableColumn fx:id="orderIdColumn" text="Order ID" prefWidth="80"/>
                        <TableColumn fx:id="orderDateColumn" text="Date" prefWidth="110"/>
                        <TableColumn fx:id="customerColumn" text="Customer" prefWidth="140"/>
                        <TableColumn fx:id="branchColumn" text="Branch" prefWidth="150"/>
                        <TableColumn fx:id="typeColumn" text="Type" prefWidth="90"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                        <TableColumn fx:id="deliveryStatusColumn" text="Delivery" prefWidth="110"/>
                        <TableColumn fx:id="totalColumn" text="Total (₪)" prefWidth="90"/>
                    </columns>
                </TableView>

                <Label fx:id="emptyLabel" text="No orders found."
                       visible="false" managed="false"
                       style="-fx-font-size: 14px; -fx-text-fill: #8d6e63;"/>
            </VBox>

            <VBox fx:id="updatePanel" spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label text="Update Order (Staff)"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>

                <Label fx:id="selectedOrderLabel" text="Select a pending order to update its status."
                       wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Set status:" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <ComboBox fx:id="statusCombo" prefWidth="160" disable="true"/>
                    <Button fx:id="updateStatusButton" text="Update Order" onAction="#updateOrderStatus"
                            disable="true"
                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"/>
                </HBox>

                <Label fx:id="updateErrorLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #c62828;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
